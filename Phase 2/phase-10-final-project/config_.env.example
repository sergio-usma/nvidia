# ═══════════════════════════════════════════════════════════════
# INNOVALABS — Autonomous Literature Factory
# Configuración de entorno (.env)
# ═══════════════════════════════════════════════════════════════
# Copiar este archivo como .env en el mismo directorio que
# docker-compose.yml y ajustar los valores según tu instalación.
# ═══════════════════════════════════════════════════════════════

# ── Timezone ──
TZ=America/Bogota

# ── Google Sheets ──
# ID del spreadsheet (extraer de la URL de Google Sheets)
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GSHEETS_SPREADSHEET_ID=REEMPLAZAR_CON_TU_SPREADSHEET_ID

# ── Rutas del Host (ajustar si tu instalación es diferente) ──

# Directorio donde Ollama almacena sus modelos
OLLAMA_MODELS_DIR=${HOME}/.ollama

# Binario de llama-cli compilado en el host
LLAMA_CLI_PATH=${HOME}/.local/bin/llama-cli

# Directorio de modelos GGUF descargados
LLAMA_MODELS_DIR=${HOME}/.cache/llama.cpp

# Nombre exacto del archivo del modelo Qwen3.5-27B
QWEN_MODEL_FILE=unsloth_Qwen3.5-27B-GGUF_Qwen3.5-27B-UD-Q4_K_XL.gguf

# ── Rutas de INNOVALABS ──

# Scripts (donde vive scout_trends.py)
INNOVALABS_SCRIPTS_DIR=/opt/innovalabs/scripts

# Directorio de salida de historias
INNOVALABS_HISTORIAS_DIR=/var/opt/innovalabs/historias

# ── n8n ──

# Puerto de la UI web de n8n
N8N_PORT=5678

# Encriptación de credenciales (generar con: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=GENERAR_CON_openssl_rand_hex_32

# Autenticación básica para la UI
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CAMBIAR_ESTA_CONTRASEÑA

# ── Ollama ──

# Puerto de la API de Ollama
OLLAMA_PORT=11434

# Máximo de modelos simultáneos en VRAM (1 = carga/descarga secuencial)
OLLAMA_MAX_LOADED_MODELS=1

# Timeout de keepalive de modelos en VRAM (segundos)
# Después de este tiempo sin uso, Ollama descarga el modelo de VRAM
OLLAMA_KEEP_ALIVE=120

# ── Writer (llama-cli sidecar) ──

# Capas a offload a GPU (-ngl). 999 = todas
LLAMA_NGL=999

# Ventana de contexto
LLAMA_CTX_SIZE=8192

# Máximo tokens de salida
LLAMA_MAX_TOKENS=8000
